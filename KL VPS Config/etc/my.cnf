# Version 00 at 2025-08-03 04:00 WIT (approx) after server elevation to Almalinux 8.10 and MariaDB 10.3.39
# Version 01 at 2025-08-03 09:51 WIT settings copied by KL RICARD from old MariaDB 5 server, as standard MariaDB 10 settings caused it to go very slow
# Version 02 at 2025-08-06 09:30 WIT Fixed compatibility issues with MariaDB 10.3.39 (Use shorthand format for large values)
# Version 03 at 2025-08-07 09:00 WIT add slow queries log, queries without indexes
# Version 04 at 2025-08-07 14:30 WIT adjust some settings (Gemini)
# Version 05 at 2025-08-11 06:45 WIT adjust key_buffer_size as phpMyAdmin suggestions
# Version 06 at 2025-08-13 08:15 WIT adjust tmp_table_size, max_heap_table_size as phpMyAdmin suggestions
# Version 07 at 2025-08-13 10:00 WIT adjust sort_buffer_size, read_rnd_buffer_size, table_open_cache as phpMyAdmin suggestions
# Version 08 at 2025-08-15 17:00 WIT restore settings as v06 as v07 degraded. Maybe too much changes at once?
# Version 09 at 2025-08-18 15:00 WIT Increase both max_heap_table_size and tmp_table_size to 128M.
# Version 10 at 2025-08-20 15:00 WIT Increase sort_buffer_size, read_rnd_buffer_size, key_buffer_size
# Version 11 at 2025-08-31 10:15 WIT Increase several settings. Change optimizer_switch
# Version 12 at 2025-09-09 WIT MariaDB 10.11 Configuration - Optimized for 16GB RAM / 8 vCPU VPS
# Version 13 at            WIT MariaDB 11.4 Configuration

#
# This group is read both by the client and the server
# use it for options that affect everything
#
[client-server]

#
# Server-specific settings
#
[mysqld]

# GENERAL --
# sql_mode is the default one for 10.11. Specified here just in case it changes in the future, as it affects webERP results
sql_mode                       = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION
user                           = mysql
default-storage-engine         = InnoDB
socket                         = /var/lib/mysql/mysql.sock
pid-file                       = /var/lib/mysql/mariadb.pid
basedir                        = /usr
datadir                        = /var/lib/mysql
tmpdir                         = /tmp
lc-messages-dir                = /usr/share/mysql
lc-messages                    = en_US
skip-external-locking
skip-name-resolve

# LOGGING --
log-error                      = /var/log/mariadb/mariadb.log
slow_query_log                 = 1
slow_query_log_file            = /var/log/mariadb/mariadb-slow.log
long_query_time                = 3
log-queries-not-using-indexes  = 1
log-slow-admin-statements      = 1
log-slow-slave-statements      = 1

# BUFFERS & CACHES --
# The most critical setting. Set to 50-70% of available RAM. 10G is a safe starting point for a 16GB VPS.
innodb_buffer_pool_size        = 10G
# The InnoDB log file size is crucial for write performance. 512M is a good value for your setup.
innodb_log_file_size           = 512M
innodb_log_buffer_size         = 16M
# Set to the number of vCPUs for modern SSDs.
innodb_write_io_threads        = 8
innodb_read_io_threads         = 8
# A higher value can improve I/O performance on SSDs. 2000 is a good starting point for generic SSDs.
innodb_io_capacity             = 2000
innodb_io_capacity_max         = 4000
# MyISAM index buffer. Since you primarily use InnoDB, this can be kept relatively small.
# Modified by KL Ricard as previous tests prove 128M is too large
key_buffer_size                = 1M

# CONNECTIONS --
max_connections                = 200
max_allowed_packet             = 256M
max_connect_errors             = 100
connect_timeout                = 600

# TABLE SETTINGS --
# This value can be increased if you have a very high number of tables. 4096 is a safe bet.
table_open_cache               = 4096
table_definition_cache         = 2000
#open_files_limit               = 65536
open_files_limit               = 100000

# TEMPORARY TABLES & SORTS --
# These values are often increased to handle complex queries without writing to disk.
tmp_table_size                 = 256M
max_heap_table_size            = 256M
join_buffer_size               = 256M
sort_buffer_size               = 8M
read_rnd_buffer_size           = 4M

# OPTIMIZER --
# The optimizer_switch settings are generally best left to the new defaults unless you have specific query issues.
# The default in 10.11 is better tuned. Let's start by using the default and re-evaluate if specific queries are slow.

# in v11: Change engine_condition_pushdown from OFF to ON, optimize_join_buffer_size from OFF to ON
# optimizer_switch = 'index_merge=on,index_merge_union=on,index_merge_sort_union=on,index_merge_intersection=on,index_merge_sort_intersection=on,engine_condition_pushdown=on,index_condition_pushdown=on,derived_merge=on,derived_with_keys=on,firstmatch=on,loosescan=on,materialization=on,in_to_exists=on,semijoin=on,partial_match_rowid_merge=on,partial_match_table_scan=on,subquery_cache=on,mrr=on,mrr_cost_based=off,mrr_sort_keys=off,outer_join_with_cache=on,semijoin_with_cache=on,join_cache_incremental=on,join_cache_hashed=on,join_cache_bka=on,optimize_join_buffer_size=on,table_elimination=on,extended_keys=on,exists_to_in=on,orderby_uses_equalities=on,condition_pushdown_for_derived=on'

# in MariaDB 10.11: default list of optimizers (optimize_join_buffer_size is already ON)
# optimizer_switch = 'index_merge=on,index_merge_union=on,index_merge_sort_union=on,index_merge_intersection=on,index_merge_sort_intersection=off,engine_condition_pushdown=off,index_condition_pushdown=on,derived_merge=on,derived_with_keys=on,firstmatch=on,loosescan=on,materialization=on,in_to_exists=on,semijoin=on,partial_match_rowid_merge=on,partial_match_table_scan=on,subquery_cache=on,mrr=off,mrr_cost_based=off,mrr_sort_keys=off,outer_join_with_cache=on,semijoin_with_cache=on,join_cache_incremental=on,join_cache_hashed=on,join_cache_bka=on,optimize_join_buffer_size=on,table_elimination=on,extended_keys=on,exists_to_in=on,orderby_uses_equalities=on,condition_pushdown_for_derived=on,split_materialized=on,condition_pushdown_for_subquery=on,rowid_filter=on,condition_pushdown_from_having=on,not_null_range_scan=off,hash_join_cardinality=off,cset_narrowing=off'

# in v12 change engine_condition_pushdown from OFF to ON, index_merge_sort_intersection from OFF to ON
# in v13 (MariaDB 11.4) commented out as caused errors starting mariadb service
# optimizer_switch = 'index_merge=on,index_merge_union=on,index_merge_sort_union=on,index_merge_intersection=on,index_merge_sort_intersection=on,engine_condition_pushdown=on,index_condition_pushdown=on,derived_merge=on,derived_with_keys=on,firstmatch=on,loosescan=on,materialization=on,in_to_exists=on,semijoin=on,partial_match_rowid_merge=on,partial_match_table_scan=on,subquery_cache=on,mrr=off,mrr_cost_based=off,mrr_sort_keys=off,outer_join_with_cache=on,semijoin_with_cache=on,join_cache_incremental=on,join_cache_hashed=on,join_cache_bka=on,optimize_join_buffer_size=on,table_elimination=on,extended_keys=on,exists_to_in=on,orderby_uses_equalities=on,condition_pushdown_for_derived=on,split_materialized=on,condition_pushdown_for_subquery=on,rowid_filter=on,condition_pushdown_from_having=on,not_null_range_scan=off,hash_join_cardinality=off,cset_narrowing=off'

# InnoDB Specific --
innodb_flush_log_at_trx_commit = 1
innodb_flush_method            = O_DIRECT
innodb_file_per_table          = 1
innodb_open_files              = 4096
innodb_buffer_pool_instances   = 8
innodb_lru_scan_depth          = 2048

[client]
socket                         = /var/lib/mysql/mysql.sock
default-character-set          = utf8mb4

[mysqldump]
quick
quote-names
max_allowed_packet             = 256M
default-character-set          = utf8mb4

[mysql]
no-auto-rehash
default-character-set          = utf8mb4

#
# include all files from the config directory
#
!includedir /etc/my.cnf.d
